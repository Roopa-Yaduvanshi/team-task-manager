# Copy this file to .env and fill in your values

# MySQL connection (use mysql+pymysql format)
# If password has @ # : / etc., URL-encode them (e.g. @ → %40)
# Example: password "Anviam@123" → Anviam%40123
DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/taskmanager

# JWT secret — use a long random string in production
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS — comma-separated origins (frontend URL)
# Example for local dev: http://127.0.0.1:5500,http://localhost:5500
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://0.0.0.0:5500,http://127.0.0.1:3000
